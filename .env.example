# ── Copier ce fichier en .env.local et remplir les valeurs ──────────────────

# Discord Webhook — Salon des DEMANDES (obligatoire)
# Les nouvelles demandes de films/séries arrivent ici
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord Webhook — Salon des RÉPONSES générales (optionnel)
# Fallback pour tout statut sans salon dédié + rappels admin
# Si absent, tout va dans DISCORD_WEBHOOK_URL
DISCORD_REPLY_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord Webhook — Salon EN ATTENTE (optionnel)
# Uniquement les remises en attente (status: pending)
# Cascade : DISCORD_PENDING_WEBHOOK_URL → DISCORD_REPLY_WEBHOOK_URL → DISCORD_WEBHOOK_URL
DISCORD_PENDING_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord Webhook — Salon APPROUVÉES (optionnel)
# Uniquement les demandes acceptées (status: added)
# Cascade : DISCORD_ADDED_WEBHOOK_URL → DISCORD_REPLY_WEBHOOK_URL → DISCORD_WEBHOOK_URL
DISCORD_ADDED_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord Webhook — Salon REFUSÉES (optionnel)
# Uniquement les demandes refusées (status: rejected)
# Cascade : DISCORD_REJECTED_WEBHOOK_URL → DISCORD_REPLY_WEBHOOK_URL → DISCORD_WEBHOOK_URL
DISCORD_REJECTED_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord Webhook — Salon NON TROUVÉES (optionnel)
# Uniquement les demandes introuvables (status: not_found)
# Cascade : DISCORD_NOT_FOUND_WEBHOOK_URL → DISCORD_REPLY_WEBHOOK_URL → DISCORD_WEBHOOK_URL
DISCORD_NOT_FOUND_WEBHOOK_URL=https://discord.com/api/webhooks/...

# URL complète du serveur Plex (ex: http://192.168.1.x:32400)
PLEX_URL=http://192.168.1.X:32400

# Token Plex (Plex Web → Dev Tools → LocalToken)
PLEX_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Mot de passe admin pour /admin (chiffres, lettres, caractères spéciaux acceptés)
ADMIN_PIN=1234

# URL publique du site (pour CORS + notifications push)
# Local : http://localhost:3000  |  Prod : https://monsite.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# VAPID Keys pour les notifications push PWA
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@plexit.local
