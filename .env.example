# ─── PLEX ───────────────────────────────────────────────────────
# URL de ton serveur Plex local (sans slash final)
PLEX_URL=http://192.168.1.XXX:32400

# Token Plex — trouve-le dans :
# Plex Web → paramètres d'un média → "..." → "Get Info" → "View XML"
# ou via : https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=ton_token_plex_ici

# ─── DISCORD ─────────────────────────────────────────────────────
# Webhook Discord — crée-le dans :
# Discord → Paramètres du salon → Intégrations → Webhooks → Nouveau webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXX

# ─── PUBLIC (visible côté client) ────────────────────────────────
# URL de ton interface Plex Web
NEXT_PUBLIC_PLEX_URL=http://192.168.1.XXX:32400/web

# Lien d'invitation Discord (optionnel)
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/TON_SERVEUR
